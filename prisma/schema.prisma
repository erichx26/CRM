// New Chapter Real Estate CRM - Prisma Schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  password      String
  name          String
  role          Role      @default(POWER_USER)
  properties    Property[]
  notes         Note[]
  activities    Activity[]
  sessions      Session[]
  resetTokens   PasswordResetToken[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

enum Role {
  ADMIN
  POWER_USER
  VIEWER
}

model Property {
  id                  String         @id @default(uuid())
  addressRaw          String
  addressNormalized   String
  city                String?
  state               String?
  zip                 String?
  status              PropertyStatus @default(NEW)
  priority            Priority       @default(MEDIUM)
  followUpDate        DateTime?
  latitude            Float?
  longitude           Float?
  redfinUrl           String?
  mapsUrl             String?
  // Redfin fields
  propertyType        String?
  beds                Int?
  baths               Float?
  squareFeet          Int?
  lotSize             Int?
  yearBuilt           Int?
  mlsNumber           String?
  source              String?
  price               Int?
  createdById         String
  createdBy          User           @relation(fields: [createdById], references: [id])
  contacts            Contact[]
  notes               Note[]
  photos              Photo[]
  thumbnailUrl        String?
  activities          Activity[]
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  @@index([addressNormalized])
  @@index([status])
  @@index([priority])
}

enum PropertyStatus {
  NEW
  CONTACTED
  NEGOTIATING
  CLOSED
  DEAD
}

enum Priority {
  HIGH
  MEDIUM
  LOW
}

model Contact {
  id          String    @id @default(uuid())
  propertyId  String
  property    Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  ownerName   String?
  emails      Email[]
  phones      Phone[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Email {
  id        String  @id @default(uuid())
  contactId String
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  value     String
  type      String? // "home", "work", "primary"
  order     Int     @default(0)

  @@index([contactId])
}

model Phone {
  id        String  @id @default(uuid())
  contactId String
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  value     String
  type      String? // "mobile", "landline", "fax"
  order     Int     @default(0)

  @@index([contactId])
}

model Note {
  id          String    @id @default(uuid())
  propertyId  String
  property    Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  content     String    @db.Text
  createdById String
  createdBy   User      @relation(fields: [createdById], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Photo {
  id          String    @id @default(uuid())
  propertyId  String
  property    Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  url         String
  filename    String
  order       Int       @default(0)
  isThumbnail Boolean   @default(false)
  createdAt   DateTime  @default(now())

  @@index([propertyId, order])
}

model Activity {
  id          String         @id @default(uuid())
  propertyId  String
  property    Property       @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  userId      String
  user        User          @relation(fields: [userId], references: [id])
  action      ActivityAction
  details     String?
  createdAt   DateTime      @default(now())
}

enum ActivityAction {
  CREATED
  UPDATED
  STATUS_CHANGED
  NOTE_ADDED
  CONTACT_ADDED
  PHOTO_ADDED
  PHOTO_DELETED
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}
